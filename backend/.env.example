# Backend Environment Variables
# Copy this file to .env and fill in your values

# Database (Supabase PostgreSQL)
# Prefer direct DB host for FastAPI + SQLAlchemy async engine.
# Format: postgresql+asyncpg://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?ssl=require
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?ssl=require&prepared_statement_cache_size=0

# JWT
# App JWT signing key (NOT Supabase service key / anon key).
# Generate with: openssl rand -hex 32
SECRET_KEY=fe6382d20cf4469a4d2af6b726528eb4faa952facfe7bd222aca2ac740d9dd23
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# CORS - comma-separated list
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]

# Cloudflare R2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_ENDPOINT_URL=https://your_cloudflare_account_id.r2.cloudflarestorage.com
# Optional: only needed if you expose public files via r2.dev/custom domain.
# This app currently uses presigned URLs for downloads.
R2_PUBLIC_URL=https://pub-<hash>.r2.dev
